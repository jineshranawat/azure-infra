# Azure subscription used for Class-1 provisioning and verification.
AZURE_SUBSCRIPTION_ID=

# Short identifier for resource names (2–10 chars, lowercase alphanumeric).
LEARNER=demo

# UK-only region: uksouth (default) or ukwest.
LOCATION=uksouth

# Owner email — applied as the 'owner' governance tag and budget alert recipient.
# Per-learner mode: set OWNER_EMAIL. Class/VDI mode: trainer sets CLASS_OWNER_EMAIL once.
OWNER_EMAIL=
CLASS_OWNER_EMAIL=training@example.com

# --- Service principal (class / VDI) — trainer fills once on golden image ---
# When all three are set, orchestrate skips browser login; learners only need
# AZURE_SUBSCRIPTION_ID + LEARNER (+ LOCATION). Never commit real secrets to git.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
